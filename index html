<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Agrinho 2026: EcoNutri Paraná</title>
    <style>
        body { 
            background-color: #f1f8f5; 
            color: #2c3e50; 
            font-family: sans-serif; 
            margin: 0;
            padding: 0; 
        }
        .topo-site {
            background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1625246333195-78d9c38ad451?q=80&w=1200');
            background-size: cover; 
            background-position: center; 
            color: white; 
            text-align: center;
            padding: 60px 20px;
        }
        .conteudo { 
            max-width: 800px; 
            margin: 30px auto; 
            padding: 25px; 
            background: white; 
            border-radius: 8px; 
            box-shadow: 0 4px 6px rgba(0,0,0,0.1); 
        }
        .lista-pilares {
            margin: 20px 0;
            padding-left: 20px;
            line-height: 1.8;
        }
        .lista-pilares li {
            margin-bottom: 10px;
        }
        .botao-projeto {
            background-color: #2e7d32; 
            color: white; 
            border: none; 
            padding: 12px 30px; 
            font-size: 16px;
            font-weight: bold; 
            border-radius: 30px; 
            cursor: pointer; 
            transition: transform 0.3s ease, background-color 0.3s ease; 
            margin-top: 15px;
            display: inline-block;
        }
        .botao-projeto:hover { 
            background-color: #1b5e20; 
            transform: scale(1.05) translateY(-2px); 
        }
    </style>
</head>
